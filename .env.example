# Copy this file to .env to override portable defaults for one machine.
# The real .env is ignored and must never be committed.

# Defaults to: ${XDG_DATA_HOME:-$HOME/.local/share}/game-compat/emulation
# EMULATION_ROOT=/path/to/emulation-data

# Normally discovered from standard native Steam locations.
# STEAM_ROOT=/path/to/Steam

# Normally discovered from Steam libraryfolders.vdf using App ID 1118310.
# RETROARCH_CONFIG=/path/to/RetroArch/retroarch.cfg
